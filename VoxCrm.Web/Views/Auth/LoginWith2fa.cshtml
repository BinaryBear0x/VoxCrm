@model VoxCrm.Web.Models.TwoFactorLoginViewModel
@{ Layout = null; }
<!doctype html><html lang="tr"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><title>İki aşamalı doğrulama</title><link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"><link rel="stylesheet" href="~/css/site.css" asp-append-version="true"></head>
<body class="bg-light"><main class="container py-5"><div class="card mx-auto shadow-sm account-security-card"><div class="card-body p-4"><h1 class="h4">Doğrulama kodu</h1><p class="text-muted">Authenticator uygulamanızdaki 6 haneli kodu girin.</p><form method="post"><div asp-validation-summary="ModelOnly" class="text-danger"></div>@Html.AntiForgeryToken()<input asp-for="ReturnUrl" type="hidden"><label asp-for="Code" class="form-label">Kod</label><input asp-for="Code" class="form-control" inputmode="numeric" autocomplete="one-time-code" autofocus><span asp-validation-for="Code" class="text-danger"></span><button class="btn btn-primary w-100 mt-3">Doğrula</button></form><a class="btn btn-link w-100 mt-2" href="/Auth/LoginWithRecoveryCode?returnUrl=@Uri.EscapeDataString(Model.ReturnUrl ?? string.Empty)">Kurtarma kodu kullan</a></div></div></main></body></html>
