@model VoxCrm.Web.Models.RecoveryCodeLoginViewModel
@{ Layout = null; }
<!doctype html><html lang="tr"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><title>Kurtarma kodu</title><link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"><link rel="stylesheet" href="~/css/site.css" asp-append-version="true"></head>
<body class="bg-light"><main class="container py-5"><div class="card mx-auto shadow-sm account-security-card"><div class="card-body p-4"><h1 class="h4">Kurtarma kodu</h1><p class="text-muted">Her kurtarma kodu yalnız bir kez kullanılabilir.</p><form method="post"><div asp-validation-summary="ModelOnly" class="text-danger"></div>@Html.AntiForgeryToken()<input asp-for="ReturnUrl" type="hidden"><label asp-for="RecoveryCode" class="form-label">Kurtarma kodu</label><input asp-for="RecoveryCode" class="form-control" autocomplete="one-time-code" autofocus><button class="btn btn-primary w-100 mt-3">Giriş yap</button></form></div></div></main></body></html>
