@model VoxCrm.Domain.Entities.VaccinationRecord
@{
    ViewData["Title"] = "Aşı Kaydı Düzenle";
    ViewData["ActiveMenu"] = "vaccines";
}

<div class="d-flex justify-content-between align-items-center pt-2 pb-2 mb-4 border-bottom">
    <div>
        <a href="/Vaccination" class="text-muted text-decoration-none small"><i class="bi bi-arrow-left me-1"></i> Aşı Takvimi</a>
        <h1 class="h3 fw-bold mb-0 mt-1">Aşı Kaydı Düzenle</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form method="post" action="/Vaccination/Edit">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ID" value="@Model.ID" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Hasta *</label>
                        <select name="PatientId" class="form-select" required data-search-select="patient" data-required="true" data-placeholder="Hasta adı, tür, ırk, çip, sahip telefonu...">
                            <option value="">-- Hasta Seç --</option>
                            @foreach (var p in (ViewBag.Patients as List<VoxCrm.Domain.Entities.Patient> ?? new()))
                            {
                                if(Model.PatientId == p.ID)
                                {
                                    <option value="@p.ID" selected>@p.Name (@p.Species)</option>
                                }
                                else
                                {
                                    <option value="@p.ID">@p.Name (@p.Species)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Aşı Türü *</label>
                        <select name="VaccineTypeId" class="form-select" required>
                            <option value="">-- Aşı Türü Seç --</option>
                            @foreach (var vt in (ViewBag.VaccineTypes as List<VoxCrm.Domain.Entities.VaccineType> ?? new()))
                            {
                                if(Model.VaccineTypeId == vt.ID)
                                {
                                    <option value="@vt.ID" selected>@vt.Name (@vt.ValidityDays gün geçerli)</option>
                                }
                                else
                                {
                                    <option value="@vt.ID">@vt.Name (@vt.ValidityDays gün geçerli)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Yapılma Tarihi *</label>
                        <input type="date" name="AdministeredDate" class="form-control" value="@Model.AdministeredDate.ToString("yyyy-MM-dd")" required>
                        <div class="form-text">Sonraki aşı tarihi, seçilen aşı türüne göre otomatik güncellenecektir.</div>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Güncelle</button>
                        <a href="/Vaccination" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
