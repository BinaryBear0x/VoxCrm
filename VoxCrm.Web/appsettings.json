{
    "ConnectionStrings": {
        "DefaultConnection": ""
    },
    "WhatsAppGateway": {
        "BaseUrl": "http://127.0.0.1:8088",
        "GatewayIssuer": "voxcrm",
        "GatewayAudience": "voxcrm-whatsapp-gateway",
        "JwtSecret": ""
    },
    "VoxCrmApi": {
        "BaseUrl": "http://127.0.0.1:5072"
    },
    "SystemHealth": {
        "EnableDockerStatus": false
    },
    "DataRetention": {
        "WhatsAppMessageDays": 30,
        "AuditDays": 365
    },
    "DataSeeding": {
        "SeedDemoData": false,
        "SystemAdmin": {
            "Enabled": false
        },
        "ProductionDealer": {
            "Enabled": false
        }
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*"
}
