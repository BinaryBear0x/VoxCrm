@model VoxCrm.Domain.Entities.PetOwner
@{
    ViewData["Title"] = "Müşteri Düzenle";
    ViewData["ActiveMenu"] = "petowners";
}

<div class="d-flex justify-content-between align-items-center pt-2 pb-2 mb-4 border-bottom">
    <div>
        <a href="/PetOwner/Details/@Model.ID" class="text-muted text-decoration-none small"><i class="bi bi-arrow-left me-1"></i> Geri Dön</a>
        <h1 class="h3 fw-bold mb-0 mt-1">Müşteri Düzenle</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form method="post" action="/PetOwner/Edit/@Model.ID">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ID" value="@Model.ID" />

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold">Ad *</label>
                            <input type="text" name="FirstName" class="form-control" value="@Model.FirstName" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold">Soyad *</label>
                            <input type="text" name="LastName" class="form-control" value="@Model.LastName" required>
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold">Telefon *</label>
                            <input type="text" name="Phone" class="form-control" value="@Model.Phone" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold">E-posta</label>
                            <input type="email" name="Email" class="form-control" value="@Model.Email">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Adres</label>
                        <textarea name="Address" class="form-control" rows="2">@Model.Address</textarea>
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="WhatsAppConsent" value="true" @(Model.WhatsAppConsent ? "checked" : "") id="waCheck">
                        <label class="form-check-label fw-semibold" for="waCheck">WhatsApp Bildirimlerine İzin Veriyor</label>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Özel Notlar</label>
                        <textarea name="Notes" class="form-control" rows="3">@Model.Notes</textarea>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Değişiklikleri Kaydet</button>
                        <a href="/PetOwner/Details/@Model.ID" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
