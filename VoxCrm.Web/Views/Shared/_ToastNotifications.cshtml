@{
    var notifications = new[]
    {
        new { Key = "Success", CssClass = "text-bg-success", Icon = "bi-check-circle-fill", Delay = 4000 },
        new { Key = "Error", CssClass = "text-bg-danger", Icon = "bi-exclamation-triangle-fill", Delay = 6500 },
        new { Key = "Warning", CssClass = "text-bg-warning", Icon = "bi-exclamation-triangle-fill", Delay = 5500 },
        new { Key = "Info", CssClass = "text-bg-info", Icon = "bi-info-circle-fill", Delay = 5000 }
    };
}

<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1090">
    @foreach (var item in notifications)
    {
        var message = TempData[item.Key]?.ToString();
        if (string.IsNullOrWhiteSpace(message))
        {
            continue;
        }

        <div class="toast align-items-center @item.CssClass border-0 shadow-sm app-toast" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="@item.Delay">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi @item.Icon me-2"></i>@message
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Kapat"></button>
            </div>
        </div>
    }
</div>
