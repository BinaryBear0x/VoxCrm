@model VoxCrm.Web.Models.ChangePasswordViewModel
@{ Layout = null; }
<!doctype html><html lang="tr"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><title>Parola değiştir</title><link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"><link rel="stylesheet" href="~/css/site.css" asp-append-version="true"></head>
<body class="bg-light"><main class="container py-5"><div class="card mx-auto shadow-sm account-security-card"><div class="card-body p-4"><h1 class="h4">Geçici parolanızı değiştirin</h1><p class="text-muted">En az 12 karakterli, benzersiz bir parola belirleyin.</p><form method="post"><div asp-validation-summary="ModelOnly" class="text-danger"></div>@Html.AntiForgeryToken()<label asp-for="CurrentPassword" class="form-label">Mevcut parola</label><input asp-for="CurrentPassword" class="form-control"><label asp-for="NewPassword" class="form-label mt-3">Yeni parola</label><input asp-for="NewPassword" class="form-control"><label asp-for="ConfirmPassword" class="form-label mt-3">Yeni parola tekrar</label><input asp-for="ConfirmPassword" class="form-control"><button class="btn btn-primary w-100 mt-4">Parolayı değiştir</button></form></div></div></main></body></html>
