@{
    ViewData["Title"] = "Yeni Randevu";
    ViewData["ActiveMenu"] = "appointments";
}

<div class="d-flex justify-content-between align-items-center pt-2 pb-2 mb-4 border-bottom">
    <div>
        <a href="/Appointment" class="text-muted text-decoration-none small"><i class="bi bi-arrow-left me-1"></i> Randevular</a>
        <h1 class="h3 fw-bold mb-0 mt-1">Yeni Randevu</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form method="post" action="/Appointment/Create">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Hasta / Sahip *</label>
                        <select name="PatientId" class="form-select" required>
                            <option value="">-- Sahip - Hasta Seç --</option>
                            @{
                                var patients = ViewBag.Patients as List<VoxCrm.Domain.Entities.Patient> ?? new();
                                
                                var ownedPatients = patients.Where(p => p.Owners.Any()).ToList();
                                var unownedPatients = patients.Where(p => !p.Owners.Any()).ToList();

                                var ownerGroups = ownedPatients
                                    .SelectMany(p => p.Owners.Select(o => new { Patient = p, Owner = o.PetOwner }))
                                    .Where(x => x.Owner != null)
                                    .GroupBy(x => x.Owner)
                                    .OrderBy(g => g.Key!.FirstName)
                                    .ToList();

                                foreach (var group in ownerGroups)
                                {
                                    <optgroup label="@group.Key!.FirstName @group.Key!.LastName (@group.Key!.Phone)">
                                        @foreach (var item in group)
                                        {
                                            <option value="@item.Patient.ID">@item.Patient.Name (@item.Patient.Species)</option>
                                        }
                                    </optgroup>
                                }

                                if (unownedPatients.Any())
                                {
                                    <optgroup label="Sahipsiz Hastalar">
                                        @foreach (var p in unownedPatients)
                                        {
                                            <option value="@p.ID">@p.Name (@p.Species)</option>
                                        }
                                    </optgroup>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Randevu Tarihi ve Saati *</label>
                        <input type="datetime-local" name="ScheduledAt" class="form-control" required>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-8">
                            <label class="form-label fw-semibold">Randevu Türü *</label>
                            <select name="AppointmentType" class="form-select" required>
                                <option value="Muayene">Muayene</option>
                                <option value="Aşı">Aşı</option>
                                <option value="Ameliyat">Ameliyat</option>
                                <option value="Tıraş">Tıraş</option>
                                <option value="Kontrol">Kontrol</option>
                            </select>
                        </div>
                        <div class="col-4">
                            <label class="form-label fw-semibold">Süre (dk)</label>
                            <input type="number" name="DurationMinutes" class="form-control" value="30" min="10" max="240">
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Geliş Sebebi / Şikayet</label>
                        <textarea name="Reason" class="form-control" rows="3" placeholder="Hasta sahibinin ifadesiyle şikayet..."></textarea>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                        <a href="/Appointment" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
