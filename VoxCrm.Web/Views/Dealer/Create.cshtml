@{
    ViewData["Title"] = "Yeni Klinik";
    ViewData["ActiveMenu"] = "dealer-create";
}

<div class="d-flex justify-content-between align-items-center pt-2 pb-2 mb-4 border-bottom">
    <div>
        <a href="/Dealer" class="text-muted text-decoration-none small"><i class="bi bi-arrow-left me-1"></i> Kliniklerim</a>
        <h1 class="h3 fw-bold mb-0 mt-1">Yeni Klinik Ekle</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form method="post" action="/Dealer/Create">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Bayi *</label>
                        <select name="DealerId" class="form-select" required>
                            <option value="">-- Bayi Sec --</option>
                            @foreach (var d in (ViewBag.Dealers as List<VoxCrm.Domain.Entities.Dealer> ?? new()))
                            {
                                <option value="@d.ID">@d.CompanyName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Klinik Adi *</label>
                        <input type="text" name="Name" class="form-control" placeholder="Ornek Veteriner Klinigi" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Telefon</label>
                        <input type="tel" name="phone" class="form-control" placeholder="0212 000 00 00">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">E-posta</label>
                        <input type="email" name="Email" class="form-control" placeholder="klinik@mail.com">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Adres</label>
                        <textarea name="Address" class="form-control" rows="2" placeholder="Tam adres..."></textarea>
                    </div>
                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="IsWhatsAppEnabled" value="true" id="waEnabled">
                            <label class="form-check-label" for="waEnabled">WhatsApp Bot Entegrasyonu Aktif</label>
                        </div>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                        <a href="/Dealer" class="btn btn-outline-secondary">Iptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
