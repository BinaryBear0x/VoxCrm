ACME_EMAIL=operations@example.com
ASPNETCORE_FORWARDEDHEADERS_ENABLED=true
POSTGRES_DB=voxcrm_prod
POSTGRES_USER=voxcrm
POSTGRES_PASSWORD=generate-a-random-32-byte-value
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=voxcrm_prod;Username=voxcrm;Password=replace-me;SSL Mode=Disable
WhatsAppGateway__JwtSecret=generate-a-random-value-at-least-32-bytes
WORKER_INTERNAL_TOKEN=generate-a-separate-random-value
WORKER_SESSION_ENCRYPTION_KEY=generate-32-random-bytes-as-base64
VOXCRM_HOST_UID=995
VOXCRM_HOST_GID=986
PiiEncryption__KeyFile=/run/secrets/pii.key
PII_ENCRYPTION_KEY_FILE=/run/secrets/pii.key
DataSeeding__SystemAdmin__Enabled=true
DataSeeding__SystemAdmin__Email=admin@example.com
DataSeeding__SystemAdmin__FirstName=System
DataSeeding__SystemAdmin__LastName=Admin
DataSeeding__SystemAdmin__Password=replace-with-one-time-strong-password
DataSeeding__ProductionDealer__Enabled=true
DataSeeding__ProductionDealer__CompanyName=Fenrir Software
DataSeeding__ProductionDealer__Email=dealer@example.com
DataSeeding__ProductionDealer__Phone=
DataSeeding__ProductionDealer__FirstName=Dealer
DataSeeding__ProductionDealer__LastName=Admin
DataSeeding__ProductionDealer__Password=replace-with-another-one-time-strong-password
ALERT_EMAIL_TO=operations@example.com
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
