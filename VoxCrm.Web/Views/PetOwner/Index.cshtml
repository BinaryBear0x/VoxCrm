@model IEnumerable<VoxCrm.Domain.Entities.PetOwner>
@{
    ViewData["Title"] = "Müşteriler";
    ViewData["ActiveMenu"] = "petowners";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-2 pb-2 mb-4 border-bottom">
    <h1 class="h3 fw-bold text-dark"><i class="bi bi-people me-2 text-primary"></i>Müşteriler</h1>
    <a href="/PetOwner/Create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i> Yeni Müşteri
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" action="/PetOwner" class="d-flex gap-2" id="owner-search-form">
            <input type="text" name="search" id="owner-search-input" value="@ViewBag.Search"
                   class="form-control"
                   placeholder="Ad, soyad, telefon, e-posta, adres, hayvan adı ara..."
                   autocomplete="off"
                   data-auto-search>
            <button type="submit" class="btn btn-outline-primary">
                <i class="bi bi-search"></i>
            </button>
            <a href="/PetOwner" class="btn btn-outline-secondary" id="owner-search-clear"
               @(string.IsNullOrEmpty(ViewBag.Search as string) ? "hidden" : "")>Temizle</a>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0"
         data-search-table="/PetOwner?partial=true"
         id="owner-table-wrapper">
        @await Html.PartialAsync("_PetOwnerTablePartial", Model)
    </div>
</div>
