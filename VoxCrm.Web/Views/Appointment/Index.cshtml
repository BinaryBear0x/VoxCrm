@model IEnumerable<VoxCrm.Domain.Entities.Appointment>
@{
    ViewData["Title"] = "Randevular";
    ViewData["ActiveMenu"] = "appointments";
    var today = DateTime.Today;
}

<div class="d-flex justify-content-between align-items-center pt-2 pb-2 mb-4 border-bottom">
    <h1 class="h3 fw-bold mb-0">Randevular</h1>
    <a href="/Appointment/Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> Yeni Randevu
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Tab Navigasyonu -->
<ul class="nav nav-tabs mb-4" id="appointmentTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="list-tab" data-bs-toggle="tab" data-bs-target="#list-view" type="button" role="tab" aria-controls="list-view" aria-selected="true">Liste Görünümü</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="calendar-tab" data-bs-toggle="tab" data-bs-target="#calendar-view" type="button" role="tab" aria-controls="calendar-view" aria-selected="false">Takvim Görünümü</button>
    </li>
</ul>

<div class="tab-content" id="appointmentTabsContent">
    <!-- Liste Görünümü -->
    <div class="tab-pane fade show active" id="list-view" role="tabpanel" aria-labelledby="list-tab">
        <!-- Filtreler -->
        <div class="d-flex gap-2 mb-3 flex-wrap">
            <a href="/Appointment" class="btn btn-sm @(ViewBag.Status == null ? "btn-dark" : "btn-outline-secondary")">Tümü</a>
            <a href="/Appointment?status=Planlandı" class="btn btn-sm @(ViewBag.Status == "Planlandı" ? "btn-primary" : "btn-outline-primary")">Planlanmış</a>
            <a href="/Appointment?status=Tamamlandı" class="btn btn-sm @(ViewBag.Status == "Tamamlandı" ? "btn-success" : "btn-outline-success")">Tamamlandı</a>
            <a href="/Appointment?status=İptal" class="btn btn-sm @(ViewBag.Status == "İptal" ? "btn-danger" : "btn-outline-danger")">İptal</a>
            <a href="/Appointment?status=Gelmedi" class="btn btn-sm @(ViewBag.Status == "Gelmedi" ? "btn-warning" : "btn-outline-warning")">Gelmedi</a>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                @if (!Model.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                        <p>Bu filtrede randevu bulunamadı.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive d-none d-md-block">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Hasta</th>
                                    <th>Tarih / Saat</th>
                                    <th>Tür</th>
                                    <th>Süre</th>
                                    <th>Durum</th>
                                    <th class="text-end">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in Model)
                                {
                                    <tr class="@(a.ScheduledAt.Date == today ? "table-warning" : "")">
                                        <td class="fw-semibold">@a.Patient?.Name</td>
                                        <td>@a.ScheduledAt.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@a.AppointmentType</td>
                                        <td>@a.DurationMinutes dk</td>
                                        <td>
                                            @{
                                                var badgeClass = a.Status switch {
                                                    "Tamamlandı" => "bg-success",
                                                    "İptal" => "bg-danger",
                                                    "Gelmedi" => "bg-warning text-dark",
                                                    _ => "bg-primary"
                                                };
                                            }
                                            <span class="badge @badgeClass">@a.Status</span>
                                        </td>
                                        <td class="text-end">
                                            @if (a.Status == "Planlandı")
                                            {
                                                <form method="post" action="/Appointment/UpdateStatus" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@a.ID">
                                                    <input type="hidden" name="status" value="Tamamlandı">
                                                    <button type="submit" class="btn btn-success btn-sm" title="Tamamlandı"><i class="bi bi-check-lg"></i></button>
                                                </form>
                                                <form method="post" action="/Appointment/UpdateStatus" class="d-inline ms-1 me-1">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@a.ID">
                                                    <input type="hidden" name="status" value="Gelmedi">
                                                    <button type="submit" class="btn btn-warning btn-sm" title="Gelmedi"><i class="bi bi-person-x"></i></button>
                                                </form>
                                            }
                                            <a href="/Appointment/Edit/@a.ID" class="btn btn-primary btn-sm ms-1"><i class="bi bi-pencil"></i></a>
                                            <form method="post" action="/Appointment/Delete" class="d-inline ms-1" onsubmit="return confirm('Bu randevuyu silmek istediğinize emin misiniz?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@a.ID">
                                                <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="d-md-none">
                        @foreach (var a in Model)
                        {
                            <div class="border-bottom p-3">
                                <div class="d-flex justify-content-between">
                                    <div class="fw-semibold">@a.Patient?.Name</div>
                                    @{
                                        var bc = a.Status switch { "Tamamlandı" => "bg-success", "İptal" => "bg-danger", "Gelmedi" => "bg-warning text-dark", _ => "bg-primary" };
                                    }
                                    <span class="badge @bc">@a.Status</span>
                                </div>
                                <div class="text-muted small mb-2">@a.ScheduledAt.ToString("dd.MM.yyyy HH:mm") · @a.AppointmentType</div>
                                <div class="d-flex justify-content-end gap-1">
                                    @if (a.Status == "Planlandı")
                                    {
                                        <form method="post" action="/Appointment/UpdateStatus" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@a.ID">
                                            <input type="hidden" name="status" value="Tamamlandı">
                                            <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-check-lg"></i></button>
                                        </form>
                                    }
                                    <a href="/Appointment/Edit/@a.ID" class="btn btn-primary btn-sm"><i class="bi bi-pencil"></i></a>
                                    <form method="post" action="/Appointment/Delete" class="d-inline" onsubmit="return confirm('Bu randevuyu silmek istediğinize emin misiniz?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@a.ID">
                                        <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Takvim Görünümü -->
    <div class="tab-pane fade" id="calendar-view" role="tabpanel" aria-labelledby="calendar-tab">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div id="calendar"></div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var calendarEl = document.getElementById('calendar');
        if (calendarEl) {
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                locale: 'tr',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                buttonText: {
                    today: 'Bugün',
                    month: 'Ay',
                    week: 'Hafta',
                    day: 'Gün'
                },
                events: [
                    @foreach (var a in Model)
                    {
                        <text>
                        {
                            title: '@Html.Raw(a.Patient?.Name) - @Html.Raw(a.AppointmentType)',
                            start: '@a.ScheduledAt.ToString("yyyy-MM-ddTHH:mm:ss")',
                            end: '@a.ScheduledAt.AddMinutes(a.DurationMinutes).ToString("yyyy-MM-ddTHH:mm:ss")',
                            url: '/Appointment/Edit/@a.ID',
                            backgroundColor: '@(a.Status == "Tamamlandı" ? "#198754" : a.Status == "İptal" ? "#dc3545" : a.Status == "Gelmedi" ? "#ffc107" : "#0d6efd")',
                            borderColor: '@(a.Status == "Tamamlandı" ? "#198754" : a.Status == "İptal" ? "#dc3545" : a.Status == "Gelmedi" ? "#ffc107" : "#0d6efd")'
                        },
                        </text>
                    }
                ]
            });
            
            var calendarTab = document.getElementById('calendar-tab');
            calendarTab.addEventListener('shown.bs.tab', function () {
                calendar.render();
            });
        }
    });
</script>
