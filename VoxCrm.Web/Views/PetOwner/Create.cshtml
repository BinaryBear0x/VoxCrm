@{
    ViewData["Title"] = "Yeni Müşteri";
    ViewData["ActiveMenu"] = "petowners";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-2 pb-2 mb-4 border-bottom">
    <div>
        <a href="/PetOwner" class="text-muted text-decoration-none small">
            <i class="bi bi-arrow-left me-1"></i> Müşteriler
        </a>
        <h1 class="h3 fw-bold text-dark mb-0 mt-1">Yeni Müşteri Ekle</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form method="post" action="/PetOwner/Create">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ad <span class="text-danger">*</span></label>
                        <input type="text" name="FirstName" class="form-control" placeholder="Ahmet" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Soyad <span class="text-danger">*</span></label>
                        <input type="text" name="LastName" class="form-control" placeholder="Yılmaz" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Telefon <span class="text-danger">*</span></label>
                        <input type="tel" name="Phone" class="form-control" placeholder="0532 123 45 67" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">E-posta</label>
                        <input type="email" name="Email" class="form-control" placeholder="ornek@mail.com">
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="WhatsAppConsent" value="true" id="whatsappConsent">
                            <label class="form-check-label" for="whatsappConsent">
                                <i class="bi bi-whatsapp text-success me-1"></i> WhatsApp bildirimlerine izin veriyor
                            </label>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i> Kaydet
                        </button>
                        <a href="/PetOwner" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
