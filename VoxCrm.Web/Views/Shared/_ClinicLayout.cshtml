<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VoxCrm</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />

</head>
<body>
    @await Html.PartialAsync("_ToastNotifications")

    <header class="navbar navbar-top sticky-top flex-md-nowrap p-0 shadow-sm">
        <a class="navbar-brand col-md-3 col-lg-2 me-0 px-3" href="/">VoxCrm</a>
        <button class="navbar-toggler position-absolute d-md-none collapsed" type="button"
                data-bs-toggle="collapse" data-bs-target="#sidebarMenu" aria-label="Menu" style="background-color: var(--primary-color);">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="navbar-nav ms-auto">
            <div class="nav-item text-nowrap d-flex align-items-center">
                <div class="dropdown me-2">
                    <button class="btn btn-sm btn-primary dropdown-toggle quick-action-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-lightning-charge me-1"></i> Hızlı İşlem
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end quick-action-menu">
                        <li><a class="dropdown-item" href="/PetOwner/Create"><i class="bi bi-person-plus"></i> Yeni Müşteri</a></li>
                        <li><a class="dropdown-item" href="/Patient/Create"><i class="bi bi-heart-pulse"></i> Yeni Hasta</a></li>
                        <li><a class="dropdown-item" href="/Appointment/Create"><i class="bi bi-calendar-plus"></i> Randevu Ekle</a></li>
                        <li><a class="dropdown-item" href="/Vaccination/Create"><i class="bi bi-capsule"></i> Aşı Kaydı</a></li>
                        <li><a class="dropdown-item" href="/Finance/Create"><i class="bi bi-receipt"></i> Borç Ekle</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/ServiceItem/Create"><i class="bi bi-tag"></i> Hizmet Ekle</a></li>
                    </ul>
                </div>
                <span class="nav-link text-muted d-none d-md-inline px-3 small fw-semibold">
                    <i class="bi bi-person-circle me-1 text-primary"></i>@User.Identity?.Name
                </span>
                <form method="post" action="/Auth/Logout" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger px-3 py-1 me-3 ms-2" style="border-radius: var(--radius-sm);">
                        <i class="bi bi-box-arrow-right me-1"></i> Çıkış
                    </button>
                </form>
            </div>
        </div>
    </header>

    <div class="container-fluid">
        <div class="row">
            <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block bg-white sidebar collapse">
                <div class="sidebar-sticky pt-2">

                    <h6 class="sidebar-heading">Ana Modül</h6>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "dashboard" ? "active" : "")" href="/">
                                <i class="bi bi-grid-1x2"></i> Gösterge Paneli
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "petowners" ? "active" : "")" href="/PetOwner">
                                <i class="bi bi-people"></i> Müşteriler
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "patients" ? "active" : "")" href="/Patient">
                                <i class="bi bi-heart-pulse"></i> Hastalar
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "muayeneler" ? "active" : "")" href="/Muayene">
                                <i class="bi bi-file-medical"></i> Tıbbi Kayıtlar
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "appointments" ? "active" : "")" href="/Appointment">
                                <i class="bi bi-calendar-check"></i> Randevular
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "vaccines" ? "active" : "")" href="/Vaccination">
                                <i class="bi bi-calendar2-check"></i> Aşı Takvimi
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "vaccinetypes" ? "active" : "")" href="/VaccineType">
                                <i class="bi bi-syringe"></i> Aşı Tanımları
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "finance" ? "active" : "")" href="/Finance">
                                <i class="bi bi-wallet2"></i> Finans
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "whatsapp" ? "active" : "")" href="/WhatsApp">
                                <i class="bi bi-whatsapp"></i> WhatsApp
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "services" ? "active" : "")" href="/ServiceItem">
                                <i class="bi bi-tags"></i> Hizmet Kataloğu
                            </a>
                        </li>
                    </ul>

                </div>
            </nav>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 mt-4 pb-5">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.app-toast').forEach(function (toastEl) {
                new bootstrap.Toast(toastEl).show();
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
