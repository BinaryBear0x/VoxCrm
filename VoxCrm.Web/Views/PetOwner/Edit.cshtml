@model VoxCrm.Domain.Entities.PetOwner
@{
    ViewData["Title"] = "Müşteri Düzenle";
    ViewData["ActiveMenu"] = "petowners";
}

<div class="d-flex justify-content-between align-items-center pt-2 pb-2 mb-4 border-bottom">
    <div>
        <a href="/PetOwner/Details/@Model.ID" class="text-muted text-decoration-none small"><i class="bi bi-arrow-left me-1"></i> Geri Dön</a>
        <h1 class="h3 fw-bold mb-0 mt-1">Müşteri Düzenle</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <p class="text-muted small mb-3">
                    <i class="bi bi-info-circle me-1"></i>
                    Tüm alanlar isteğe bağlıdır.
                </p>

                <form method="post" action="/PetOwner/Edit/@Model.ID" id="petOwnerEditForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ID" value="@Model.ID" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold">Ad</label>
                            <input type="text" name="FirstName" class="form-control" value="@Model.FirstName">
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold">Soyad</label>
                            <input type="text" name="LastName" class="form-control" value="@Model.LastName">
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold">Telefon</label>
                            <input type="text" name="Phone" class="form-control" value="@Model.Phone">
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold">E-posta</label>
                            <input type="email" name="Email" class="form-control" value="@Model.Email">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Adres</label>
                        <textarea name="Address" class="form-control" rows="2">@Model.Address</textarea>
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="WhatsAppConsent" value="true" @(Model.WhatsAppConsent ? "checked" : "") id="waCheck">
                        <label class="form-check-label fw-semibold" for="waCheck">WhatsApp Bildirimlerine İzin Veriyor</label>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Özel Notlar</label>
                        <textarea name="Notes" class="form-control" rows="3">@Model.Notes</textarea>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Değişiklikleri Kaydet</button>
                        <a href="/PetOwner/Details/@Model.ID" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Eksik alan onay modalı -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title" id="confirmModalLabel">
                    <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i> Eksik Bilgi
                </h5>
            </div>
            <div class="modal-body">
                <p class="mb-2">Aşağıdaki alanlar boş bırakıldı:</p>
                <ul id="missingFieldsList" class="text-muted small mb-0"></ul>
                <p class="mt-3 mb-0">Yine de kaydetmek istiyor musunuz?</p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Geri Dön</button>
                <button type="button" class="btn btn-primary" id="confirmSaveBtn">
                    <i class="bi bi-check-circle me-1"></i> Evet, Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var formEl = document.getElementById('petOwnerEditForm');
    var confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
    var confirmed = false;

    var fieldLabels = {
        'FirstName': 'Ad',
        'LastName': 'Soyad',
        'Phone': 'Telefon',
        'Address': 'Adres'
    };

    formEl.addEventListener('submit', function (e) {
        if (confirmed) return;
        var missing = [];
        Object.keys(fieldLabels).forEach(function (name) {
            var el = formEl.elements[name];
            if (el && !el.value.trim()) missing.push(fieldLabels[name]);
        });
        if (missing.length > 0) {
            e.preventDefault();
            var list = document.getElementById('missingFieldsList');
            list.innerHTML = '';
            missing.forEach(function (f) {
                var li = document.createElement('li');
                li.textContent = f;
                list.appendChild(li);
            });
            confirmModal.show();
        }
    });

    document.getElementById('confirmSaveBtn').addEventListener('click', function () {
        confirmed = true;
        confirmModal.hide();
        formEl.submit();
    });
})();
</script>
}
