@model VoxCrm.Web.Models.DealerLogsViewModel
@{
    ViewData["Title"] = "Sistem Logları";
    ViewData["ActiveMenu"] = "dealer-logs";
    var clinicNames = Model.Clinics.ToDictionary(c => c.ID, c => c.Name);
    string ClinicName(Guid? id) => id.HasValue && clinicNames.TryGetValue(id.Value, out var name) ? name : "-";
    string BadgeClass(string level) => level == "Error" ? "danger" : level == "Warning" ? "warning text-dark" : "secondary";
}

<div class="d-flex justify-content-between align-items-center pt-2 pb-2 mb-4 border-bottom">
    <div>
        <h1 class="h3 fw-bold mb-0">Sistem Logları</h1>
        <div class="text-muted small">Yapılan işlemler, hata kayıtları ve WhatsApp teslimat hataları</div>
    </div>
    <a href="/Dealer/Health" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-activity me-1"></i> Sistem Sağlığı
    </a>
</div>

<form method="get" class="row g-2 align-items-end mb-4">
    <div class="col-12 col-md-3">
        <label class="form-label small fw-semibold">Seviye</label>
        <select name="level" class="form-select form-select-sm">
            <option value="">Tümü</option>
            <option value="Info" selected="@(Model.Level == "Info")">Info</option>
            <option value="Warning" selected="@(Model.Level == "Warning")">Warning</option>
            <option value="Error" selected="@(Model.Level == "Error")">Error</option>
        </select>
    </div>
    <div class="col-12 col-md-4">
        <label class="form-label small fw-semibold">Klinik</label>
        <select name="clinicId" class="form-select form-select-sm">
            <option value="">Tüm kapsam</option>
            @foreach (var clinic in Model.Clinics)
            {
                <option value="@clinic.ID" selected="@(Model.ClinicId == clinic.ID)">@clinic.Name</option>
            }
        </select>
    </div>
    <div class="col-12 col-md-auto">
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-funnel me-1"></i> Filtrele
        </button>
    </div>
</form>

<div class="row g-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="p-3 border-bottom">
                    <h2 class="h6 fw-bold mb-0">İşlem Logları</h2>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Zaman</th>
                                <th>Seviye</th>
                                <th>Kapsam</th>
                                <th>İşlem</th>
                                <th>Kullanıcı</th>
                                <th>Mesaj</th>
                                <th>Trace</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (!Model.AuditLogs.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">Log bulunamadı.</td>
                            </tr>
                        }
                        @foreach (var log in Model.AuditLogs)
                        {
                            <tr>
                                <td class="small text-nowrap">@log.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                                <td><span class="badge bg-@BadgeClass(log.Level)">@log.Level</span></td>
                                <td class="small">@ClinicName(log.ClinicId)</td>
                                <td class="small fw-semibold">@log.Action</td>
                                <td class="small">@(log.ActorUserName ?? "-")</td>
                                <td class="small">@log.Message</td>
                                <td class="small text-muted">@log.TraceId</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="p-3 border-bottom">
                    <h2 class="h6 fw-bold mb-0">WhatsApp Hata Logları</h2>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Zaman</th>
                                <th>Klinik</th>
                                <th>Alıcı</th>
                                <th>Tip</th>
                                <th>Durum</th>
                                <th>Retry</th>
                                <th>Hata</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (!Model.WhatsAppErrors.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">WhatsApp hata kaydı yok.</td>
                            </tr>
                        }
                        @foreach (var item in Model.WhatsAppErrors)
                        {
                            <tr>
                                <td class="small text-nowrap">@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                                <td class="small">@ClinicName(item.ClinicID)</td>
                                <td>@item.PhoneNumber</td>
                                <td>@item.NotificationType</td>
                                <td><span class="badge bg-danger">@item.Status</span></td>
                                <td>@item.RetryCount</td>
                                <td class="small text-muted">@(item.LastError ?? "-")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
