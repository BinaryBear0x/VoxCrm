@model IEnumerable<VoxCrm.Domain.Entities.Patient>
@{
    ViewData["Title"] = "Hastalar";
    ViewData["ActiveMenu"] = "patients";
}

<div class="d-flex justify-content-between align-items-center pt-2 pb-2 mb-4 border-bottom">
    <h1 class="h3 fw-bold mb-0">Hastalar</h1>
    <a href="/Patient/Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> Yeni Hasta
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" action="/Patient" class="d-flex gap-2" id="patient-search-form">
            <input type="text" name="search" id="patient-search-input" value="@ViewBag.Search"
                   class="form-control form-control-sm"
                   placeholder="Ad, tür, ırk, sahip, yaş, cinsiyet (erkek/dişi) ara..."
                   autocomplete="off"
                   data-auto-search>
            <button type="submit" class="btn btn-outline-primary btn-sm"><i class="bi bi-search"></i></button>
            <a href="/Patient" class="btn btn-outline-secondary btn-sm" id="patient-search-clear"
               @(string.IsNullOrEmpty(ViewBag.Search as string) ? "hidden" : "")>Temizle</a>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0"
         data-search-table="/Patient?partial=true"
         id="patient-table-wrapper">
        @await Html.PartialAsync("_PatientTablePartial", Model)
    </div>
</div>
