@model VoxCrm.Domain.Entities.Clinic
@{
    ViewData["Title"] = "Klinik Ayarları";
    ViewData["ActiveMenu"] = "settings";
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
    <h1 class="h3 fw-bold mb-0">Klinik Ayarları</h1>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

@if (Model == null)
{
    <div class="alert alert-warning">Klinik bilgisi bulunamadı. Lütfen bayi panelinizden klinik ekleyin.</div>
}
else
{
    <div class="row justify-content-start">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form method="post" action="/ClinicSettings">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="ID" value="@Model.ID">

                        <h6 class="text-muted text-uppercase small mb-3">Genel Bilgiler</h6>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Klinik Adı *</label>
                            <input type="text" name="Name" class="form-control" value="@Model.Name" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Telefon</label>
                            <input type="tel" name="phone" class="form-control" value="@Model.phone">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">E-posta</label>
                            <input type="email" name="Email" class="form-control" value="@Model.Email">
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Adres</label>
                            <textarea name="Address" class="form-control" rows="3">@Model.Address</textarea>
                        </div>

                        <hr>
                        <h6 class="text-muted text-uppercase small mb-3">WhatsApp Bot Ayarları</h6>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="IsWhatsAppEnabled" value="true"
                                       id="waEnabled" @(Model.IsWhatsAppEnabled ? "checked" : "")>
                                <label class="form-check-label fw-semibold" for="waEnabled">WhatsApp Bot Entegrasyonu</label>
                            </div>
                            <div class="form-text">Aktif edilirse Hangfire her gece otomatik mesaj listesi olusturur.</div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">WhatsApp Phone Number ID</label>
                            <input type="text" name="WhatsAppPhoneNumberId" class="form-control" value="@Model.WhatsAppPhoneNumberId" placeholder="Meta API'dan alinan numara ID">
                        </div>
                        <div class="border rounded p-3 mb-4">
                            <div class="form-check form-switch mb-3">
                                <input class="form-check-input" type="checkbox" name="WhatsAppSendWindowEnabled" value="true"
                                       id="waWindowEnabled" @(Model.WhatsAppSendWindowEnabled ? "checked" : "")>
                                <label class="form-check-label fw-semibold" for="waWindowEnabled">Gönderim penceresi aktif</label>
                            </div>
                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="form-label small fw-semibold">Başlangıç</label>
                                    <input type="time" name="WhatsAppSendWindowStart" class="form-control" value="@Model.WhatsAppSendWindowStart.ToString("HH:mm")">
                                </div>
                                <div class="col-6">
                                    <label class="form-label small fw-semibold">Bitiş</label>
                                    <input type="time" name="WhatsAppSendWindowEnd" class="form-control" value="@Model.WhatsAppSendWindowEnd.ToString("HH:mm")">
                                </div>
                                <div class="col-12">
                                    <label class="form-label small fw-semibold">Zaman dilimi</label>
                                    <input type="text" name="WhatsAppTimeZoneId" class="form-control" value="@Model.WhatsAppTimeZoneId">
                                </div>
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Kaydet</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
