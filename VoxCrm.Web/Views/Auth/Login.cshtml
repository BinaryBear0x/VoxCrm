@{
    ViewData["Title"] = "Giriş Yap";
    Layout = null; // Login sayfasında sidebar olmasın
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - VoxCrm</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />
    <style>
        body { background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%); min-height: 100vh; }
        .login-card { border-radius: 16px; }
        .brand-icon { font-size: 2.5rem; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center py-4">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-8 col-md-6 col-lg-4">
                <!-- Logo -->
                <div class="text-center mb-4">
                    <div class="brand-icon text-white"><i class="bi bi-heart-pulse-fill brand-accent"></i></div>
                    <h1 class="h3 fw-bold text-white mt-2">VoxCrm</h1>
                    <p class="text-white-50 small">Veteriner Yönetim Sistemi</p>
                </div>

                <!-- Kart -->
                <div class="card login-card border-0 shadow-lg">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 text-center">Hesabınıza Giriş Yapın</h5>

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger small py-2">
                                <i class="bi bi-exclamation-triangle me-1"></i>
                                E-posta veya şifre hatalı.
                            </div>
                        }

                        <form method="post" action="/Auth/Login">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl">

                            <div class="mb-3">
                                <label class="form-label fw-semibold small">E-posta</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                    <input type="email" name="email" class="form-control" placeholder="ornek@mail.com" required autofocus>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold small">Şifre</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                    <input type="password" name="password" class="form-control" placeholder="••••••" required>
                                </div>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Giriş Yap
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <p class="text-center text-white-50 small mt-3">
                    &copy; @DateTime.Now.Year VoxCrm · Tüm hakları saklıdır.
                </p>
            </div>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
