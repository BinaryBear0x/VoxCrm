@model VoxCrm.Web.Models.MfaSetupViewModel
@{ Layout = null; }
<!doctype html><html lang="tr"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><title>MFA kurulumu</title><link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"><link rel="stylesheet" href="~/css/site.css" asp-append-version="true"></head>
<body class="bg-light"><main class="container py-5"><div class="card mx-auto shadow-sm account-security-card"><div class="card-body p-4">@if(Model.IsCompleted){<h1 class="h4">MFA etkinleştirildi</h1><p>Bu kodları çevrimdışı ve güvenli bir yerde saklayın. Tekrar gösterilmeyecekler.</p><ul class="font-monospace">@foreach(var code in Model.RecoveryCodes){<li>@code</li>}</ul><a href="/" class="btn btn-primary w-100">Devam et</a>}else{<h1 class="h4">Authenticator kurulumu</h1><ol><li>Authenticator uygulamasında yeni hesap ekleyin.</li><li>Anahtarı elle girin: <code>@Model.SharedKey</code></li><li>Üretilen 6 haneli kodu doğrulayın.</li></ol><form method="post">@Html.AntiForgeryToken()<input asp-for="SharedKey" type="hidden"><input asp-for="AuthenticatorUri" type="hidden"><label asp-for="Code" class="form-label">Doğrulama kodu</label><input asp-for="Code" class="form-control" inputmode="numeric" autocomplete="one-time-code"><span asp-validation-for="Code" class="text-danger"></span><button class="btn btn-primary w-100 mt-3">MFA'yı etkinleştir</button></form>}</div></div></main></body></html>
