@model VoxCrm.Domain.Entities.ServiceItem
@{
    ViewData["Title"] = "Yeni Hizmet/Ürün Ekle";
    ViewData["ActiveMenu"] = "settings";
}

<div class="d-flex justify-content-between align-items-center pt-2 pb-2 mb-4 border-bottom">
    <h1 class="h3 fw-bold mb-0">Yeni Hizmet/Ürün Ekle</h1>
    <a href="/ServiceItem" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Geri Dön
    </a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form action="/ServiceItem/Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Hizmet / Ürün Adı</label>
                        <input type="text" name="Name" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Açıklama</label>
                        <textarea name="Description" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Fiyat (TL)</label>
                        <input type="number" step="0.01" name="Price" class="form-control" required />
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" name="IsActive" value="true" checked id="isActiveCheck">
                        <label class="form-check-label fw-semibold" for="isActiveCheck">Aktif</label>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
