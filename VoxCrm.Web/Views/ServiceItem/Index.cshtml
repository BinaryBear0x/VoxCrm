@model IEnumerable<VoxCrm.Domain.Entities.ServiceItem>
@{
    ViewData["Title"] = "Hizmetler ve Ürünler";
    ViewData["ActiveMenu"] = "settings";
    var includeArchived = ViewBag.IncludeArchived is true;
}

<div class="d-flex justify-content-between align-items-center pt-2 pb-2 mb-4 border-bottom">
    <h1 class="h3 fw-bold mb-0">Hizmet ve Ürün Listesi</h1>
    <div class="d-flex gap-2">
        <a href="/ServiceItem?includeArchived=@((!includeArchived).ToString().ToLowerInvariant())" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-archive me-1"></i> @(includeArchived ? "Arşivi Gizle" : "Arşivi Göster")
        </a>
        <a href="/ServiceItem/Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Yeni Ekle
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Hizmet / Ürün Adı</th>
                        <th>Açıklama</th>
                        <th>Fiyat</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Name</td>
                            <td class="text-muted small">@item.Description</td>
                            <td class="fw-semibold">@item.Price.ToString("N2") TL</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Pasif</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (item.IsActive)
                                {
                                    <a href="/ServiceItem/Edit/@item.ID" class="btn btn-sm btn-outline-primary">Düzenle</a>
                                    <form action="/ServiceItem/Delete" method="post" class="d-inline" data-confirm="Bu hizmeti arşivlemek istediğinize emin misiniz?">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.ID" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Arşivle</button>
                                    </form>
                                }
                                else
                                {
                                    <form action="/ServiceItem/Restore" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.ID" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Geri Al</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if(!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Kayıt bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
