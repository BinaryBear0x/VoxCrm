@{
    ViewData["Title"] = "Erisim Reddedildi";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Erisim Reddedildi - VoxCrm</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); min-height: 100vh; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center">
    <div class="text-center text-white px-4">
        <div style="font-size:4rem;">🔒</div>
        <h1 class="h3 fw-bold mt-3">Erisim Reddedildi</h1>
        <p class="text-white-50 mt-2">Bu sayfaya erismek icin gerekli yetkiniz bulunmuyor.</p>
        <a href="/" class="btn btn-outline-light mt-3">Ana Sayfaya Don</a>
        <form method="post" action="/Auth/Logout" class="d-inline ms-2">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger mt-3">Cikis Yap</button>
        </form>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
