<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VoxCrm Bayi Paneli</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />

</head>
<body>
    @await Html.PartialAsync("_ToastNotifications")

    <header class="navbar navbar-top sticky-top flex-md-nowrap p-0 shadow-sm">
        <a class="navbar-brand col-md-3 col-lg-2 me-0 px-3" href="/Dealer">VoxCrm Bayi</a>
        <button class="navbar-toggler position-absolute d-md-none collapsed" type="button"
                data-bs-toggle="collapse" data-bs-target="#sidebarMenu" aria-label="Menu" class="navbar-dealer">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="navbar-nav ms-auto">
            <div class="nav-item text-nowrap d-flex align-items-center">
                <span class="nav-link text-muted d-none d-md-inline px-3 small fw-semibold">
                    <i class="bi bi-building me-1 text-secondary"></i>@User.Identity?.Name
                </span>
                <form method="post" action="/Auth/Logout" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger px-3 py-1 me-3 ms-2 radius-sm">
                        <i class="bi bi-box-arrow-right me-1"></i> Çıkış
                    </button>
                </form>
            </div>
        </div>
    </header>

    <div class="container-fluid">
        <div class="row">
            <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block bg-white sidebar collapse">
                <div class="sidebar-sticky pt-2">

                    <h6 class="sidebar-heading">Bayi Paneli</h6>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "dealer" ? "active" : "")" href="/Dealer">
                                <i class="bi bi-building"></i> Kliniklerim
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "dealer-create" ? "active" : "")" href="/Dealer/Create">
                                <i class="bi bi-plus-circle"></i> Yeni Klinik Ekle
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "dealer-health" ? "active" : "")" href="/Dealer/Health">
                                <i class="bi bi-activity"></i> Sistem Sağlığı
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "dealer-logs" ? "active" : "")" href="/Dealer/Logs">
                                <i class="bi bi-journal-text"></i> Loglar
                            </a>
                        </li>
                    </ul>

                    <h6 class="sidebar-heading">Ayarlar</h6>
                    <ul class="nav flex-column mb-3">
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "settings" ? "active" : "")" href="/ClinicSettings">
                                <i class="bi bi-gear"></i> Klinik Ayarları
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "whatsapp" ? "active" : "")" href="/WhatsApp">
                                <i class="bi bi-whatsapp"></i> WhatsApp
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/hangfire" target="_blank">
                                <i class="bi bi-clock-history"></i> Hangfire Paneli
                            </a>
                        </li>
                    </ul>

                </div>
            </nav>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 mt-4 pb-5">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.app-toast').forEach(function (toastEl) {
                new bootstrap.Toast(toastEl).show();
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
