@model VoxCrm.Web.Models.CreateClinicViewModel
@{
    ViewData["Title"] = "Yeni Klinik";
    ViewData["ActiveMenu"] = "dealer-create";
}

<div class="d-flex justify-content-between align-items-center pt-2 pb-2 mb-4 border-bottom">
    <div>
        <a href="/Dealer" class="text-muted text-decoration-none small"><i class="bi bi-arrow-left me-1"></i> Kliniklerim</a>
        <h1 class="h3 fw-bold mb-0 mt-1">Yeni Klinik Ekle</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form method="post" action="/Dealer/Create">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Klinik Adi *</label>
                        <input asp-for="Name" class="form-control" placeholder="Ornek Veteriner Klinigi">
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Telefon</label>
                        <input asp-for="Phone" type="tel" class="form-control" placeholder="0212 000 00 00">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">E-posta</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="klinik@mail.com">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Adres</label>
                        <textarea asp-for="Address" class="form-control" rows="2" placeholder="Tam adres..."></textarea>
                    </div>
                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsWhatsAppEnabled" class="form-check-input" type="checkbox" id="waEnabled">
                            <label class="form-check-label" for="waEnabled">WhatsApp Bot Entegrasyonu Aktif</label>
                        </div>
                    </div>
                    <hr class="my-4">
                    <h2 class="h6 fw-bold mb-3">Ilk Klinik Kullanicisi</h2>
                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label asp-for="InitialUserFirstName" class="form-label fw-semibold">Ad *</label>
                            <input asp-for="InitialUserFirstName" class="form-control">
                            <span asp-validation-for="InitialUserFirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="InitialUserLastName" class="form-label fw-semibold">Soyad *</label>
                            <input asp-for="InitialUserLastName" class="form-control">
                            <span asp-validation-for="InitialUserLastName" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="InitialUserEmail" class="form-label fw-semibold">E-posta *</label>
                            <input asp-for="InitialUserEmail" type="email" class="form-control">
                            <span asp-validation-for="InitialUserEmail" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                        <a href="/Dealer" class="btn btn-outline-secondary">Iptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
